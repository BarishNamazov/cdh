{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": {
      ".env": "deny",
      ".env.*": "deny",
      "node_modules/**": "deny",
      "*": "allow"
    },
    "bash": {
      "rm -rf *": "deny",
      "rm -r *": "deny",
      "git push *--force": "deny",
      "git push -f": "deny",
      "*": "allow"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "external_directory": "ask",
    "doom_loop": "ask"
  },
  "instructions": ["**/AGENTS.md", "design/**/*.md"],
  "agent": {
    "spec-writer": {
      "mode": "subagent",
      "permission": {
        "edit": "allow",
        "bash": "deny"
      }
    },
    "reviewer": {
      "mode": "subagent",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "scout": {
      "mode": "subagent",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    }
  }
}
