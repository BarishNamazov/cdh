{
  "name": "@sdg/cdh",
  "version": "0.0.0",
  "description": "Concept Design Harness for pi-powered concept-design repositories.",
  "type": "module",
  "private": false,
  "bin": {
    "cdh": "./bin/cdh.js"
  },
  "files": [
    "bin",
    "src",
    "extensions",
    "agents",
    "skills",
    "prompts",
    "catalog",
    "templates",
    "fixtures",
    "docs",
    "PROGRESS.md",
    "README.md"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "test": "bun test",
    "validate:fixture": "bun run scripts/validate-fixture.ts fixtures/valid-app",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.49",
    "ts-morph": "27.0.2"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.3",
    "@earendil-works/pi-tui": "0.80.3",
    "@types/bun": "1.3.14",
    "typebox": "1.1.38",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "pi": {
    "name": "cdh",
    "extensions": [
      "./extensions/spike-probes.ts"
    ]
  }
}
