{
  "name": "@mit-sdg/cdh",
  "version": "0.1.11",
  "description": "Concept Design Harness for OpenCode-powered concept-design repositories.",
  "type": "module",
  "private": false,
  "bin": {
    "cdh": "./bin/cdh.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./src/*": "./src/*",
    "./opencode/*": "./.opencode/*",
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "src",
    "templates",
    ".opencode",
    "catalog",
    "fixtures",
    "design",
    "docs",
    "opencode.json",
    "AGENTS.md",
    "README.md"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "lint": "biome check --error-on-warnings",
    "format": "biome check --write",
    "format:check": "biome check",
    "test": "rm -rf dist && bun test",
    "validate:fixture": "bun run scripts/validate-fixture.ts fixtures/valid-app",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.17.16",
    "ts-morph": "27.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/bun": "1.3.14",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@mit-sdg/sync-engine": "*"
  }
}
