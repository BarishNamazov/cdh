{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["bun-types"],
    "baseUrl": ".",
    "paths": {
      "@utils/*": ["src/utils/*"],
      "@concepts/*": ["src/concepts/*"],
      "@engine/*": ["src/engine/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
