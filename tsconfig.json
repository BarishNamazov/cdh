{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["bun-types"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "bin/**/*.ts",
    "src/**/*.ts",
    ".opencode/**/*.ts",
    "scripts/**/*.ts",
    "fixtures/**/*.ts"
  ],
  "exclude": [
    "fixtures/sync-engine-app"
  ]
}
